# StockSight — environment variables
#
# Copy this file to .env and fill in the values before running locally.
# None of these are required for basic operation; the app runs with defaults.
#
# Flask settings
FLASK_DEBUG=false       # Set to true during local development for auto-reload
PORT=5000               # Port the Flask server listens on

# Optional: if you want to restrict CORS to specific origins
# CORS_ORIGINS=https://yourdomain.com
